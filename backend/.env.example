# Este archivo es solo para correr el backend directamente con `node` sin Docker.
# Si usás Docker Compose, ignorá este archivo — usá el .env en la raíz del proyecto.
#
# Copiar a backend/.env para dev local sin Docker:

PORT=3000
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tp_chat
DB_USER=postgres
DB_PASSWORD=postgres
JWT_SECRET=dev_secret_local
JWT_EXPIRES_IN=7d
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@tpchat.com
TURNSTILE_SECRET=1x0000000000000000000000000000000AA
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
EMAIL_RATE_LIMIT_PER_IP_PER_DAY=3
