# Copiar este archivo a .env y completar los valores reales.
# El .env NUNCA se commitea al repo — está en .gitignore.
# Docker Compose lee este .env automáticamente.

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generá uno seguro con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cambia_esto_en_produccion
JWT_EXPIRES_IN=7d

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@tpchat.com

# ─── Cloudflare Turnstile (CAPTCHA) ───────────────────────────────────────────
# Clave de prueba (siempre pasa, para desarrollo): 1x0000000000000000000000000000000AA
# Clave real: https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SECRET=1x0000000000000000000000000000000AA

# ─── OpenTelemetry / Tracing ──────────────────────────────────────────────────
# Vacío = tracing deshabilitado.
# Local con grafana-agent: http://grafana-agent:4318
# Render (directo a Grafana Cloud): https://otlp-gateway-prod-us-east-0.grafana.net/otlp
OTEL_EXPORTER_OTLP_ENDPOINT=
# Solo necesario cuando se envía directo a Grafana Cloud (sin agent):
# Authorization=Basic <base64(instanceId:apiKey)>
OTEL_EXPORTER_OTLP_HEADERS=

# ─── Grafana Cloud (para docker compose --profile monitoring) ─────────────────
# Obtener desde grafana.com → tu stack → Details → "Send metrics" / "Send traces"
GRAFANA_CLOUD_PROM_URL=https://prometheus-prod-XX.grafana.net/api/prom/push
GRAFANA_CLOUD_PROM_USER=123456
GRAFANA_CLOUD_TEMPO_ENDPOINT=tempo-prod-XX.grafana.net:443
GRAFANA_CLOUD_TEMPO_USER=123456
GRAFANA_CLOUD_API_KEY=tu_grafana_cloud_api_key
